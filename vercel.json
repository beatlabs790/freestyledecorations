{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "css/**",
          "js/**",
          "*.html",
          "*.svg",
          "*.jpg",
          "*.png"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/css/(.*)",
      "headers": { "cache-control": "public, max-age=31536000, immutable" },
      "dest": "/css/$1"
    },
    {
      "src": "/js/(.*)",
      "headers": { "cache-control": "public, max-age=31536000, immutable" },
      "dest": "/js/$1"
    },
    {
      "src": "/(unnamed.*\\.jpg)",
      "dest": "/$1"
    },
    {
      "src": "/(zephyr-logo\\.png)",
      "dest": "/$1"
    },
    {
      "src": "/(favicon\\.svg)",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}
